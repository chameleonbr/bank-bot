# --- FINBANK FULL STACK ENVIRONMENT ---
# This file is loaded by Docker Compose automatically at the project root.
# You can override the default values by creating a .env file and setting the vars.

# --- Global Settings ---
ENVIRONMENT=development
ALGORITHM=HS256

# --- Backend Settings ---
DATABASE_URL=sqlite:////app/data/finbank.db
ACCESS_TOKEN_EXPIRE_MINUTES=30

# YOU MUST SET THIS: Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=yoursecretkeyhere

# --- Agent Settings ---
BACKEND_URL=http://backend:8000
REDIS_URL=redis://redis:6379/0

# YOU MUST SET THIS: Your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here
